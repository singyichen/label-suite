direction: right
...@../shared/_base

title: Chapter 2 — Related Work {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

platforms: 2.1 Platform Survey {
  class: tool

  label_studio: Label Studio {
    class: [base; multiple]
    style.fill: MistyRose
    ls1: Feature-rich {class: base}
    ls2: Tedious setup {class: base}
  }
  codabench: CodaBench {
    class: [base; multiple]
    style.fill: MistyRose
    cb1: Academic standard {class: base}
    cb2: Poor UX {class: base}
  }
  gap: Architectural Gap {
    class: warning
    label: No integrated\nlabeling + scoring\n+ leaderboard
  }
  label_studio -> gap
  codabench -> gap
}

chinese: 2.3 Chinese NLP Annotation {
  class: module

  cn1: Word Segmentation {class: base}
  cn2: Domain Terminology {class: base}
  medical: Medical / Healthcare {
    class: [base; multiple]
  }
  sentiment: Sentiment / Psychology {
    class: [base; multiple]
  }
}

evaluation: 2.4 Evaluation & Leaderboard {
  class: highlight

  benchmark: No Public Chinese Benchmarks {
    class: warning
  }
  contamination: Data Contamination {
    class: warning
    label: Models pre-exposed\nto test answers
  }
  solution: Third-party Scoring {
    class: base
    label: Answers hidden\nserver-side
  }
  benchmark -> solution: solved by
  contamination -> solution: solved by
}

platforms -> chinese: context for
chinese -> evaluation: motivates
