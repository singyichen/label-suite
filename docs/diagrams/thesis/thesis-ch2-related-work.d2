direction: right
...@../shared/_base

title: Chapter 2 — Related Work {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

platforms: 2.1 Platform Survey {
  class: tool

  label_studio: Label Studio {
    class: [base; multiple]
    style.fill: MistyRose
    ls1: Feature-rich {class: base}
    ls2: Tedious setup {class: base}
    ls3: No annotator management {class: base}
    ls4: No dataset analytics {class: base}
  }
  gap: Differentiation Opportunity {
    class: warning
    label: No config-driven launch\n+ no annotator management\n+ no built-in dataset analytics
  }
  label_studio -> gap
}

chinese: 2.3 Chinese NLP Annotation {
  class: module

  cn1: Word Segmentation {class: base}
  cn2: Domain Terminology {class: base}
  medical: Medical / Healthcare {
    class: [base; multiple]
  }
  sentiment: Sentiment / Psychology {
    class: [base; multiple]
  }
}

platforms -> chinese: context for
